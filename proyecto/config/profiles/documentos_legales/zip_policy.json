{
  "parte_detection_patterns": [
    "PARTE[_]?\\d+",
    "PARTE[_]?[IVX]+",
    "[IVX]+[_]?PARTE",
    "CSV[_]?PARTE",
    "^PARTE$"
  ],
  "strip_roman_suffix_from_token": true,
  "parte_keep_extensions": [".csv"],
  "general_remove_extensions": [
    ".mp4", ".avi", ".mov", ".mkv", ".wmv", ".flv", ".webm", ".m4v", ".3gp",
    ".msg", ".eml", ".emlx", ".ost", ".pst"
  ]
}
